<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
  </head>
  <body>
    <h1>Welcome to EJS</h1>
    <p><%= message %></p>

    <h2>Products</h2>
    <ul>
      <% products.forEach(product => { %>
        <li><%= product.name %> - $<%= product.price %></li>
      <% }) %>
    </ul>
  </body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Admin</title>
</head>
<body>
    <h1>Product Admin Interface</h1>
    <ul>
        <% products.forEach(product => { %>
            <li>
                <%= product.name %>-
                <%= product.price %>-
                <%= product.description %>-

                <a href="/<%= product._id %>/edit">Edit</a>
                <a href="/<%= product._id %>/delete">Delete</a>
            </li>
        <% }) %>
    </ul>
</body>
</html>